# ---- ENS Hold'em frontend environment ----
# Copy to .env.local and fill in.

# Reown (WalletConnect) Cloud project ID — https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=43bdd1b8c477ac4d4a4264a14a8472f8

# Alchemy API key — used for all mainnet reads (ENS resolution, avatars,
# $ENS token balance, delegation status).  https://dashboard.alchemy.com
NEXT_PUBLIC_ALCHEMY_KEY=your-alchemy-key

# Etherscan API key (optional; reserved for extra lookups such as tx links)
NEXT_PUBLIC_ETHERSCAN_KEY=your-etherscan-key

# Deployed Cloudflare Worker origin (no trailing slash)
NEXT_PUBLIC_WORKER_URL=https://epoker-worker.your-subdomain.workers.dev
